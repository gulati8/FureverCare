# Database
POSTGRES_USER=furevercare
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_SECURE_PASSWORD
POSTGRES_DB=furevercare

# Backend
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING
FRONTEND_URL=https://furevercare.gulatilabs.me

# Storage
STORAGE_PROVIDER=s3
S3_BUCKET=CHANGE_THIS_TO_YOUR_BUCKET_NAME
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Email
# Brevo API key for transactional emails
BREVO_API_KEY=

# Reminder worker
REMINDER_PROCESS_CRON=0 9 * * *
REMINDER_PROCESS_TIMEZONE=America/New_York

# Note: Copy this file to .env and fill in the values
# Generate a secure JWT_SECRET with: openssl rand -base64 32
# Generate a secure DB password with: openssl rand -base64 24
