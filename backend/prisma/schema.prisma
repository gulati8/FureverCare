generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model audit_log {
  id                   Int          @id @default(autoincrement())
  entity_type          String       @db.VarChar(100)
  entity_id            Int
  action               String       @db.VarChar(50)
  changed_by           Int?
  source               String       @default("manual") @db.VarChar(50)
  source_pdf_upload_id Int?
  old_values           Json?
  new_values           Json?
  changed_fields       String[]
  ip_address           String?      @db.VarChar(45)
  user_agent           String?
  created_at           DateTime?    @default(now()) @db.Timestamptz(6)
  users                users?       @relation(fields: [changed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pdf_uploads          pdf_uploads? @relation(fields: [source_pdf_upload_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([changed_by], map: "idx_audit_log_changed_by")
  @@index([created_at], map: "idx_audit_log_created_at")
  @@index([entity_type, entity_id], map: "idx_audit_log_entity")
  @@index([source], map: "idx_audit_log_source")
}

model cms_blocks {
  id         Int        @id @default(autoincrement())
  page_id    Int?
