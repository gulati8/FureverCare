  cms_pages  cms_pages? @relation(fields: [page_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([page_id], map: "idx_cms_blocks_page_id")
  @@index([page_id, sort_order], map: "idx_cms_blocks_sort_order")
}

model cms_pages {
  id           Int          @id @default(autoincrement())
