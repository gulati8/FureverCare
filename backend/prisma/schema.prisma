model document_uploads {
  id                         Int                    @id @default(autoincrement())
  pet_id                     Int
  uploaded_by                Int
  filename                   String                 @db.VarChar(255)
  original_filename          String                 @db.VarChar(255)
  file_path                  String
  file_size                  Int
  mime_type                  String                 @db.VarChar(100)
  media_type                 String                 @db.VarChar(20)
  status                     String                 @default("pending") @db.VarChar(50)
  detected_type              String?                @db.VarChar(100)
  classification_confidence  Int?
  classification_explanation String?
  processing_started_at      DateTime?              @db.Timestamptz(6)
  processing_completed_at    DateTime?              @db.Timestamptz(6)
  error_message              String?
  created_at                 DateTime?              @default(now()) @db.Timestamptz(6)
  user_tag                   String?                @db.VarChar(100)
  user_description           String?
  date_taken                 DateTime?              @db.Timestamptz(6)
  body_area                  String?                @db.VarChar(100)
  document_group_id          String?                @db.Uuid
  page_number                Int?                   @default(1)
  group_name                 String?                @db.VarChar(255)
  deleted_at                 DateTime?              @db.Timestamptz(6)
  document_extractions       document_extractions[]
  pets                       pets                   @relation(fields: [pet_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                      users                  @relation(fields: [uploaded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([deleted_at], map: "idx_document_uploads_deleted_at")
  @@index([detected_type], map: "idx_document_uploads_detected_type")
  @@index([document_group_id], map: "idx_document_uploads_group_id", where: raw("(document_group_id IS NOT NULL)"))
  @@index([media_type], map: "idx_document_uploads_media_type")
  @@index([pet_id], map: "idx_document_uploads_pet_id")
  @@index([status], map: "idx_document_uploads_status")
  @@index([uploaded_by], map: "idx_document_uploads_uploaded_by")
}

