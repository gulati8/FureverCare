  pet_vaccinations           pet_vaccinations[]
  pet_vets                   pet_vets[]
  users                      users                        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  share_tokens               share_tokens[]

  @@index([share_id], map: "idx_pets_share_id")
  @@index([user_id], map: "idx_pets_user_id")
}

model share_tokens {
  id               Int       @id @default(autoincrement())
  pet_id           Int
  token            String    @unique @db.VarChar(32)
  label            String?   @db.VarChar(100)
  pin_hash         String?   @db.VarChar(255)
  expires_at       DateTime? @db.Timestamptz(6)
  created_by       Int
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  access_count     Int?      @default(0)
  last_accessed_at DateTime? @db.Timestamptz(6)
  is_active        Boolean?  @default(true)
  users            users     @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pets             pets      @relation(fields: [pet_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_share_tokens_expires_at")
  @@index([pet_id], map: "idx_share_tokens_pet_id")
  @@index([token], map: "idx_share_tokens_token")
}

model subscription_config {
  id         Int       @id @default(autoincrement())
  key        String    @unique @db.VarChar(100)
  value      Json
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_by Int?
  users      users?    @relation(fields: [updated_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([key], map: "idx_subscription_config_key")
}

model users {
  id                                                              Int                          @id @default(autoincrement())
  email                                                           String                       @unique @db.VarChar(255)
  password_hash                                                   String                       @db.VarChar(255)
  name                                                            String                       @db.VarChar(255)
  phone                                                           String?                      @db.VarChar(50)
  created_at                                                      DateTime?                    @default(now()) @db.Timestamptz(6)
  updated_at                                                      DateTime?                    @default(now()) @db.Timestamptz(6)
  is_admin                                                        Boolean                      @default(false)
  stripe_customer_id                                              String?                      @db.VarChar(255)
  subscription_status                                             String?                      @default("free") @db.VarChar(50)
  subscription_tier                                               String?                      @default("free") @db.VarChar(50)
  subscription_current_period_end                                 DateTime?                    @db.Timestamptz(6)
  subscription_stripe_id                                          String?                      @db.VarChar(255)
  audit_log                                                       audit_log[]
  document_extractions                                            document_extractions[]
  document_uploads                                                document_uploads[]
  email_templates                                                 email_templates[]
  image_extractions                                               image_extractions[]
  image_uploads                                                   image_uploads[]
  password_reset_tokens                                           password_reset_tokens[]
  pdf_extractions                                                 pdf_extractions[]
  pdf_uploads                                                     pdf_uploads[]
  pet_invitations                                                 pet_invitations[]
  pet_owners_pet_owners_invited_byTousers                         pet_owners[]                 @relation("pet_owners_invited_byTousers")
  pet_owners_pet_owners_user_idTousers                            pet_owners[]                 @relation("pet_owners_user_idTousers")
  pet_reminder_notifications                                      pet_reminder_notifications[]
  pet_reminder_rules_pet_reminder_rules_created_by_user_idTousers pet_reminder_rules[]         @relation("pet_reminder_rules_created_by_user_idTousers")
  pet_reminder_rules_pet_reminder_rules_updated_by_user_idTousers pet_reminder_rules[]         @relation("pet_reminder_rules_updated_by_user_idTousers")
  pets                                                            pets[]
  share_tokens                                                    share_tokens[]
  subscription_config                                             subscription_config[]

  @@index([is_admin], map: "idx_users_is_admin", where: raw("(is_admin = true)"))
  @@index([stripe_customer_id], map: "idx_users_stripe_customer_id")
  @@index([subscription_status], map: "idx_users_subscription_status")
}
