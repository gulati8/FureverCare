{
  "name": "furevercare-api",
  "version": "1.0.0",
  "description": "FureverCare API - Pet Emergency Health Card Service",
  "main": "dist/index.js",
  "scripts": {
    "prisma:generate": "prisma generate",
    "dev": "npm run prisma:generate && tsx watch src/index.ts",
    "dev:worker": "npm run prisma:generate && tsx watch src/jobs/worker.ts",
    "build": "npm run prisma:generate && tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/jobs/worker.js",
    "test": "npm run prisma:generate && node --test src/**/*.test.js",
    "db:migrate:prepare": "tsx src/db/prepare-prisma-migrations.ts",
    "db:migrate": "npm run prisma:generate && npm run db:migrate:prepare && prisma migrate deploy",
    "db:migrate:dev": "npm run prisma:generate && prisma migrate dev",
    "db:migrate:status": "prisma migrate status",
    "db:pull": "prisma db pull",
    "db:seed": "node dist/db/seed.js",
    "db:seed:dev": "tsx src/db/seed.ts",
    "db:seed:cms": "node dist/db/seed-cms.js",
    "db:seed:cms:dev": "tsx src/db/seed-cms.ts",
    "db:seed:cms-empty-state": "node dist/db/seed-cms-empty-state.js",
    "db:seed:cms-empty-state:dev": "tsx src/db/seed-cms-empty-state.ts",
    "test:backend": "npm run prisma:generate && vitest run src/models/health-records.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-s3": "^3.980.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@getbrevo/brevo": "^5.0.4",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.74.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exif-reader": "^2.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.4",
    "pg": "^8.11.3",
    "prisma": "^7.7.0",
    "rate-limit-redis": "^4.3.1",
    "sharp": "^0.33.5",
    "stripe": "^20.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^7.2.0",
    "@vitest/ui": "^1.6.1",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  }
}
